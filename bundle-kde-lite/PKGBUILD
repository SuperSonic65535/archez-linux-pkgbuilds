# Maintainer: SuperSonic65535 <SuperSonic65535@proton.me>
pkgname=bundle-kde-lite
pkgver=$(date +%Y.%-m.%-d)
pkgrel=$(expr $(date +%-S) + $(expr 60 \* $(date +%-M)) + $(expr 3600 \* $(date +%-H)))
pkgdesc='KDE Plasma desktop - minimal bundle (no apps included)'
arch=(any)
url='https://github.com/SuperSonic65535/archez-linux-pkgbuilds'
install=install.install
depends=(
	plasma-login-manager
	plasma-nm
	plasma-pa
	plasma-workspace
	polkit-kde-agent
	powerdevil power-profiles-daemon python-gobject
	systemsettings
)
optdepends=(
	'plasmalogin: Default login manager for KDE Plasma'
	'sddm: Alternative login manager for KDE Plasma and other X11/Wayland environments'
	'sddm-kcm: KDE Plasma System Settings module for SDDM login manager'
)
package() {
	cp -r "$srcdir/../files/usr" "$pkgdir"
	"$srcdir/../../set-default-permissions.sh" "$pkgdir"
	chmod +x "$pkgdir/usr/share/libalpm/scripts/bundle-kde-lite-install"
}
