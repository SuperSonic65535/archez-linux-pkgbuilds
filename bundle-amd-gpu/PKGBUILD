# Maintainer: SuperSonic65535 <SuperSonic65535@proton.me>
pkgname=bundle-amd-gpu
pkgver=$(date +%Y.%-m.%-d)
pkgrel=$(expr $(date +%-S) + $(expr 60 \* $(date +%-M)) + $(expr 3600 \* $(date +%-H)))
pkgdesc='Open source AMD/ATI GPU drivers - all-in-one bundle (64bit+32bit)'
arch=(x86_64)
url='https://github.com/SuperSonic65535/archez-linux-pkgbuilds'
depends=(
	# Core firmware + OpenGL + VAAPI/VDPAU
	linux-firmware
	mesa lib32-mesa
	# Vulkan
	vulkan-mesa-layers lib32-vulkan-mesa-layers
	vulkan-radeon lib32-vulkan-radeon
	# OpenCL
	opencl-mesa lib32-opencl-mesa
)
