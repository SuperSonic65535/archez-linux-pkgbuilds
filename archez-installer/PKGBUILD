# Maintainer: Dankcuddlybear <dankcuddlybear@proton.me>
pkgname=archez-installer
pkgver=$(date +%Y.%-m.%-d)
pkgrel=$(expr $(date +%-S) + $(expr 60 \* $(date +%-M)) + $(expr 3600 \* $(date +%-H)))
pkgdesc='ArchEZ Linux installer'
arch=(any)
url='https://github.com/SuperSonic65535/archez-linux-pkgbuilds'
replaces=('zestiso-installer')
depends=(
	arch-install-scripts
	kdialog
	sudo
)
package() {
	cp -r "$srcdir/../files/usr" "$pkgdir"
	"$srcdir/../../set-default-permissions.sh" "$pkgdir"
	CDIR="$(pwd)"
	for DIR in "$pkgdir/usr/bin" \
	"$pkgdir/usr/lib/archez-installer"; do
		cd "$DIR"; chmod +x *
	done; cd "$CDIR"
}
