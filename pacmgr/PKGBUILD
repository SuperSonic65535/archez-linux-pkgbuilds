# Maintainer: SuperSonic65535 <SuperSonic65535@proton.me>
pkgname=pacmgr
pkgver=$(date +%Y.%-m.%-d)
pkgrel=$(expr $(date +%-S) + $(expr 60 \* $(date +%-M)) + $(expr 3600 \* $(date +%-H)))
pkgdesc='EXPERIMENTAL GUI Configurable update manager for pacman with update alerts, automatic downloads and installs'
arch=(any)
url='https://github.com/SuperSonic65535/archez-linux-pkgbuilds'
depends=(
	dialog
	libnotify
    pacman-contrib
)
optdepends=(
	'pacnews: Read news for installed packages before updating'
)
package() {
	cp -r "$srcdir/../files/etc" "$pkgdir"
	cp -r "$srcdir/../files/usr" "$pkgdir"
	"$srcdir/../../set-default-permissions.sh" "$pkgdir"
	chmod +x "$pkgdir/usr/bin"/*
	chmod +x "$pkgdir/usr/lib/pacmgr"/*.sh
	chmod 750 "$pkgdir/etc/sudoers.d"
}
